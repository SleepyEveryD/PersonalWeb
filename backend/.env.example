# Port the server listens on. Render injects its own PORT at runtime.
PORT=8787

# Comma-separated list of allowed frontend origins (CORS).
# Local dev: the Vite dev server.
# Render: set to your deployed frontend Static Site URL.
ALLOWED_ORIGIN=http://localhost:5173

# Anthropic API key — only needed once the chatbot is wired up.
ANTHROPIC_API_KEY=
